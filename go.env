# Shai-Hulud defense - Go module integrity pinning.
# See allora-network/skills (skills/shai-hulud-defense) for rationale.
#
# IMPORTANT: This file is NOT auto-loaded by the Go toolchain. The Go
# toolchain only reads $GOROOT/go.env and $(go env GOENV). This file is
# consumed exclusively by .github/workflows/go-hardened.yml (which calls
# allora-network/ci-workflows-private/.github/workflows/go-install-hardened.yml
# pinned by commit SHA). Do NOT `source` it locally; GOFLAGS=-mod=readonly
# will break codegen and tool-install flows if applied to a dev shell.
GOPROXY=https://proxy.golang.org,direct
GOSUMDB=sum.golang.org
GOFLAGS=-mod=readonly
# Explicitly empty exemption knobs so an inherited environment cannot
# bypass sumdb verification for any module path.
GOPRIVATE=
GONOSUMDB=
GOINSECURE=
